{
  "name": "team-task-manager",
  "private": true,
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "install-all": "npm install",
    "dev": "concurrently \"cd backend && npm run dev\" \"cd frontend && npm run dev\"",
    "build": "cd frontend && npm run build",
    "start": "cd backend && npm start",
    "postinstall": "npm run build"
  },
  "devDependencies": {
    "concurrently": "^8.2.0"
  }
}
